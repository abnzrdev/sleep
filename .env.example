# Copy this file to .env and update values for your machine.
# Then start with: ./run.sh --no-open

# App host/port
HOST=127.0.0.1
PORT=5000
MAX_PORT=5100
DEBUG=0
SECRET_KEY=change-this-local-secret
# DATABASE_URL=sqlite:////absolute/path/to/sleep.db
NIM_API_KEY=nvapi-your-key-here

# Local demo mode settings
EXTERNAL_SENSOR_ONLY=1
TEST_MODE=1

# External sender remote control (Pi)
RPI_AUTOCONTROL=0
RPI_SSH_HOST=192.168.8.151
RPI_SSH_PORT=22
RPI_SSH_USER=admin
RPI_SSH_PASSWORD=12345678
RPI_SEND_WORKDIR=/home/admin
RPI_SEND_SCRIPT=scripts/send_data.py
RPI_SEND_PYTHON=python

# Optional overrides for sender target destination
# RPI_TARGET_HOST=100.64.162.59
# RPI_TARGET_PORT=5005
